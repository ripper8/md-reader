{
  "manifest_version": 3,
  "name": "MDReader - Interactive Markdown & Mermaid Viewer",
  "version": "1.0.0",
  "description": "Преглеждайте и редактирайте Markdown файлове с красиви Mermaid диаграми директно в Chrome.",
  "permissions": [
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": [
        "file:///*/*.md",
        "file:///*/*.markdown",
        "file:///*/*.mdx",
        "http://*/*.md",
        "https://*/*.md",
        "http://*/*.markdown",
        "https://*/*.markdown"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "index.html",
        "assets/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
